# ============================================================
# Нейро 32 — Frontend environment variables
# Copy this file to .env.production.local and fill in values.
# Variables starting with VITE_ are embedded in the JS bundle
# and are visible to end users — do NOT put secrets here.
# ============================================================

# URL of your deployed backend API (no trailing slash)
# Example: https://api.mysite.ru
# In development, leave empty — Vite proxies /api to localhost
VITE_API_URL=https://api.mysite.ru

# Base path — set to "/" for root, or "/subdir/" if hosted in a subdirectory
BASE_PATH=/
