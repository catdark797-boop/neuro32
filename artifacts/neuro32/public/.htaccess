# SPA fallback for reg.ru Apache hosting.
# If the requested file/dir exists, serve it (assets, sitemap, etc).
# Otherwise rewrite to /index.html so the SPA router handles the URL.
RewriteEngine On
RewriteBase /

# Defense-in-depth: even if a .map file slips into the deploy zip, refuse to
# serve it. Source-maps are uploaded to Sentry only and must never be public.
# (Build also runs `sourcemap: 'hidden'` + sentryVitePlugin
# `filesToDeleteAfterUpload`, and scripts/zip-for-regru.mjs strips .map from
# the zip — this is the third belt.)
<FilesMatch "\.map$">
  Require all denied
</FilesMatch>

# If the request is not for a real file or directory…
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# …and is not an API call (those never hit reg.ru anyway, just safety net)…
RewriteCond %{REQUEST_URI} !^/api/
# …then serve the SPA shell.
RewriteRule ^ /index.html [L]

# Long cache for hashed assets (vite appends -[hash] so they're immutable).
<FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|webp|svg|avif)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# No caching for the HTML shell so new deploys are picked up instantly.
<FilesMatch "\.html$">
  Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>

# Compression — try brotli first, fall back to gzip. Both are no-ops on
# reg.ru if their Apache build doesn't ship the module, so this is safe to
# deploy regardless. AddOutputFilterByType ensures only text-y mimes get
# squeezed; binary assets (.woff2, images) are already compressed.
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript application/javascript application/json image/svg+xml application/xml
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml application/xml
</IfModule>

# ── Security headers ─────────────────────────────────────────────────────
# Content-Security-Policy — defence against XSS and data exfiltration.
# Allowlist enumerates every external origin our SPA legitimately talks to:
#   * Sentry SDK & Y.Metrika both load JS at runtime
#   * Sentry posts events to ingest.de.sentry.io
#   * Y.Metrika posts to mc.yandex.ru and counts via image beacon
#   * Google Fonts CSS comes from googleapis, font files from gstatic
#   * API calls go to neuro-32-production.up.railway.app (Railway)
#   * Telegram links open in new tab, no script load — not in CSP
# 'unsafe-inline' on script-src kept for the small Y.Metrika init snippet
# in index.html; if it ever gets hashed we should switch to nonce/hash.
<IfModule mod_headers.c>
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://mc.yandex.ru https://*.sentry.io https://browser.sentry-cdn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://mc.yandex.ru https://*.sentry.io https://maps.google.com; connect-src 'self' https://*.sentry.io https://*.ingest.de.sentry.io https://*.ingest.sentry.io https://mc.yandex.ru wss://mc.yandex.ru https://api-server-production-0d71.up.railway.app; frame-src 'self' https://mc.yandex.ru; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://api-server-production-0d71.up.railway.app; object-src 'none'; upgrade-insecure-requests"

  # Stops MIME-sniffing attacks where a .jpg becomes interpreted as .html.
  Header always set X-Content-Type-Options "nosniff"

  # Backstop for older browsers that don't honour CSP frame-ancestors.
  Header always set X-Frame-Options "DENY"

  # Control how much of the previous URL leaks via Referer header.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Disable browser features the SPA doesn't use — protects against
  # malicious 3rd-party iframes if frame-src ever expands.
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

  # HSTS — 6 months, include subdomains. Only meaningful on HTTPS, but
  # reg.ru forces HTTPS via cert anyway, so this just hardens.
  Header always set Strict-Transport-Security "max-age=15552000; includeSubDomains"

  # Yandex/Google honour these, though they're advisory.
  Header always set X-Robots-Tag "index, follow"
</IfModule>
