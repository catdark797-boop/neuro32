# ============================================================
# Нейро 32 — API Server environment variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ----- Required in ALL environments -------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/neuro32

# HTTP port the server will listen on
PORT=3000

# Secret for signing session cookies — use a long random string
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ----- Required in PRODUCTION only --------------------------

# Comma-separated list of allowed CORS origins (your frontend URL)
# Example: https://mysite.ru,https://www.mysite.ru
ALLOWED_ORIGINS=https://mysite.ru

# Admin account seed — created on first start if not found in DB
ADMIN_EMAIL=admin@mysite.ru
ADMIN_PASSWORD=ChangeMe_VeryStrongPassword_123!

# ----- ЮMoney integration -----------------------------------

# Your ЮMoney wallet number (e.g. 4100118...)
YOOMONEY_RECEIVER=4100100000000000

# Secret key from ЮMoney notification settings (for webhook signature)
YOOMONEY_SECRET=your_ymoney_secret_here

# Your frontend URL — used to build YooMoney success redirect URL
FRONTEND_URL=https://mysite.ru

# ----- Optional ---------------------------------------------

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Set to "production" in production — affects cookie security and CORS strictness
NODE_ENV=development
